{
  "name": "cypress-project",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:allure": "cypress run --env allure=true",
    "allure:generate": "allure generate allure-results --clean",
    "allure:open": "allure open",
    "allure:report": "npm run test:allure && npm run allure:generate && npm run allure:open",
    "allure:clear": "rm -rf allure-results allure-report",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:cypress": "eslint cypress/**/*.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:format": "npm run lint && npm run format:check",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@shelex/cypress-allure-plugin": "^2.41.2",
    "allure-commandline": "^2.36.0",
    "cypress": "^15.10.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cypress": "^3.0.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^15.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "prettier": "^3.8.1"
  }
}
